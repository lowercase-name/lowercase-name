<script is:inline>
    const colors = [
        {
            dark: `#000`,
            light: `#fff`,
            name: `literally just black and white`,
        },
        {
            dark: `#062b5b`,
            light: `#f6f992`,
            name: `walmart in an anime with washed out colors`,
        },
        {
            dark: `#2d2617`,
            light: `#f8ee98`,
            name: `worn-out caution tape`,
        },
        {
            dark: `#420c65`,
            light: `#faff70`,
            name: `wario`,
        },
        {
            dark: `#980364`,
            light: `#faffff`,
            name: `nice homemade jam`,
        },
        {
            dark: `#1f2937`,
            light: `#a0ffc3`,
            name: `legally distinct spotify`,
        },
        {
            dark: `#182297`,
            light: `#feffed`,
            name: `commodorn't 64`,
        },
        {
            dark: `#590949`,
            light: `#a8fee9`,
            name: `christmas but kinda evil and twisted`,
        },
        {
            dark: `#265b4d`,
            light: `#fff`,
            name: `mid-tier coffee packaging at okay roasting company`,
        },
        {
            dark: `#0e5382`,
            light: `#f7feed`,
            name: `niche european luxury chocolate`,
        },
        {
            dark: `#070d20`,
            light: `#e1ecbe`,
            name: `medical terminal in a horror game`,
        },
        {
            dark: `#5f2e2d`,
            light: `#fff2df`,
            name: `guy trying to figure out what old paper looked like but he only sees them in videogames`,
        },
        {
            dark: `#15017d`,
            light: `#affed1`,
            name: `artificial kids' drink brand discontinued in 2003`,
        },
        {
            dark: `#03272b`,
            light: `#ffe4e7`,
            name: `literally just two colors i really like`,
        },
        {
            dark: `#362368`,
            light: `#fafa09`,
            name: `caution tape 2: the reckoning`,
        },
    ];

    function hexToRgbA(hex) {
        var c;
        if (/^#([A-Fa-f0-9]{3}){1,2}$/.test(hex)) {
            c = hex.substring(1).split("");
            if (c.length == 3) {
                c = [c[0], c[0], c[1], c[1], c[2], c[2]];
            }
            c = "0x" + c.join("");
            return (
                "rgba(" +
                [(c >> 16) & 255, (c >> 8) & 255, c & 255].join(",") +
                ",255)"
            );
        }
        throw new Error("Bad Hex");
    }

    let prevRoll;
    let colorDark;
    let colorLight;

    function reroll() {
        function roll() {
            return Math.floor(Math.random() * colors.length);
        }

        let currentRoll = roll();

        if (currentRoll === prevRoll) {
            while (currentRoll === prevRoll) {
                currentRoll = roll();
            }
        }

        const colorPicked = currentRoll;
        colorDark = colors[colorPicked].dark;
        colorLight = colors[colorPicked].light;
        const colorName = colors[colorPicked].name;

        const htmlStyle = document.querySelector("html");

        htmlStyle.setAttribute(
            "style",
            `--color-dark: ${colorDark};--color-light: ${colorLight};--color-name: "${colorName}"`,
        );
        prevRoll = colorPicked;
        if (!document.startViewTransition) {
            lightDark();
            return;
        }
        document.startViewTransition(() => {
            lightDark();
        });
    }

    function lightDark() {
        if (document.querySelector("as-dithered-image")) {
            const themeCheck = window?.matchMedia?.(
                "(prefers-color-scheme:dark)",
            )?.matches
                ? "dark"
                : "light";
            const setImgColors = document.querySelectorAll("as-dithered-image");
            setImgColors.forEach((tag) => {
                if (themeCheck == "dark") {
                    tag.setAttribute("lightrgba", hexToRgbA(colorDark));
                    tag.setAttribute("darkrgba", hexToRgbA(colorLight));
                } else {
                    tag.setAttribute("darkrgba", hexToRgbA(colorDark));
                    tag.setAttribute("lightrgba", hexToRgbA(colorLight));
                }
            });
        }
    }

    if (document.querySelector("as-dithered-image")) {
        var match = window?.matchMedia?.("(prefers-color-scheme:dark)");
        match.addEventListener("change", (e) => {
            if (!document.startViewTransition) {
                lightDark();
                return;
            }
            document.startViewTransition(() => {
                lightDark();
            });
        });
    }

    reroll();
</script>
