<script>
    let prevRolls: number[] = [];
    let colorPicked: number;

    function reroll() {
        function roll() {
            return Math.floor(Math.random() * 14 + 1);
        }

        let currentRoll = roll();
        prevRolls = prevRolls.slice(-5);

        if (prevRolls.includes(currentRoll)) {
            while (prevRolls.includes(currentRoll)) {
                currentRoll = roll();
            }
        }

        colorPicked = currentRoll;

        prevRolls.push(colorPicked);

        lightDark();
    }

    let colorDark;
    let colorLight;

    function lightDark() {
        function getVar(cssVar) {
            return window
                .getComputedStyle(document.documentElement)
                .getPropertyValue(`--${cssVar}`);
        }

        function hexToRgbA(hex) {
            var c;
            if (/^#([A-Fa-f0-9]{3}){1,2}$/.test(hex)) {
                c = hex.substring(1).split("");
                if (c.length == 3) {
                    c = [c[0], c[0], c[1], c[1], c[2], c[2]];
                }
                c = "0x" + c.join("");
                return (
                    "rgba(" +
                    [(c >> 16) & 255, (c >> 8) & 255, c & 255].join(",") +
                    ",255)"
                );
            }
            throw new Error("Bad Hex");
        }

        const contrastCheck = window?.matchMedia?.("(prefers-contrast: more)")
            ?.matches
            ? "more"
            : null;

        if (contrastCheck == "more") {
            colorDark = `#000`;
            colorLight = `#fff`;
            document.documentElement.style.setProperty(
                "--color-name",
                `"literally black and white"`,
            );
        } else {
            colorDark = getVar(`color-${colorPicked}-dark`);
            colorLight = getVar(`color-${colorPicked}-light`);
            document.documentElement.style.setProperty(
                "--color-dark",
                `var(--color-${colorPicked}-dark)`,
            );
            document.documentElement.style.setProperty(
                "--color-light",
                `var(--color-${colorPicked}-light)`,
            );
            document.documentElement.style.setProperty(
                "--color-name",
                `var(--color-${colorPicked}-name)`,
            );
        }

        if (document.querySelector("as-dithered-image")) {
            const themeCheck = window?.matchMedia?.(
                "(prefers-color-scheme:dark)",
            )?.matches
                ? "dark"
                : "light";
            const setImgColors = document.querySelectorAll("as-dithered-image");
            setImgColors.forEach((tag) => {
                if (themeCheck == "dark") {
                    tag.setAttribute("lightrgba", hexToRgbA(colorDark));
                    tag.setAttribute("darkrgba", hexToRgbA(colorLight));
                } else {
                    tag.setAttribute("darkrgba", hexToRgbA(colorDark));
                    tag.setAttribute("lightrgba", hexToRgbA(colorLight));
                }
            });
        }
    }

    if (document.querySelector("as-dithered-image")) {
        var match = window?.matchMedia?.("(prefers-color-scheme:dark)");
        match.addEventListener("change", (e) => {
            if (!document.startViewTransition) {
                lightDark();
                return;
            }
            document.startViewTransition(() => {
                lightDark();
            });
        });
    }
    const letter: any = document.querySelector(
        'button[aria-label="switch to random color scheme"]',
    );
    letter.addEventListener("click", () => {
        if (!document.startViewTransition) {
            reroll();
            return;
        }
        document.startViewTransition(() => {
            reroll();
        });
    });

    reroll();
</script>
